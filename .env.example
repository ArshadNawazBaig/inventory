# ──────────────────────────────────────────────────────────────────────────
# StockFlow environment variables (copy to .env and fill in — never commit .env)
# Values are validated at boot via @stockflow/config. See docs/PROJECT_SETUP.md.
# ──────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000

# Datastores (local dev via infrastructure/docker/docker-compose.yml)
MONGODB_URI=mongodb://localhost:27017/stockflow
REDIS_URL=redis://localhost:6379

# Auth (Better Auth) — added in Phase P3
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# Storage (Cloudinary) — added in Phase P4
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend) — added in Phase P3
RESEND_API_KEY=

# Payments (Stripe) — added in Phase P11
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Monitoring (Sentry)
SENTRY_DSN=

# Analytics (PostHog)
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Public (browser-exposed — never put secrets here)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
